; jmp 09
    jmp @l09
    out 1 3
    $l09 out 0 3
    out 10 2
; jle 10
    jle v10 @l101
    out 1 3
    $l101 out 0 3
    out 44 2
    mov -10 v10
    jle v10 @l102
    out 1 3
    $l102 out 0 3
    out 44 2
