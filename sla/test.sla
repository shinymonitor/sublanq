; adr 18
    adr v18 temp
    sub 28 temp
    out temp 3
    out 10 2
; dwt & drd
    mov msg ptr
    $write_loop 
    dwt 48 ptr
    inc ptr
    inc cnt
    mov cnt temp
    sub 5 temp
    jge temp @read_loop
    jmp @write_loop
    $read_loop 
    drd msg temp
    jle temp @end
    out temp 2
    inc msg
    jmp @read_loop
    $end 
