; run with dbg io
; this program is used as tests for assembler and emulator
; Every expected output is a 0

v00, v01, v02, v03, v04, v05, v06, v07, v08, v09, v10, v11, v12, v13, v14, v15, v16, v17, v18, v21
msg * 49, 49, 49, 49, 49, 48, 48, 48, 48, 48, 48, 10, 0
ptr, cnt, temp
__start__
; zer 00
    mov 9 v00
    zer v00
    out v00 3
    out 10 2
; inc 01
    mov -1 v01
    inc v01
    out v01 3
    out 10 2
